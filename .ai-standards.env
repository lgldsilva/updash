# Per-repo coverage gate for ai-standards pre-push (committed, no secrets).
# Keep in sync with .github/workflows/ci.yml COVER_PKGS and Sonar inclusions.
# Race-tests still run on ./... ; floor ≥90% applies only here.
COVER_PKGS="./internal/model/... ./internal/config/... ./internal/sizefmt/... ./internal/cli/... ./internal/retention/... ./internal/upgrade/..."
COVERAGE_MIN=90
